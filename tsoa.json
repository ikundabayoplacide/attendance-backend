{
  "entryFile": "server.ts",
  "noImplicitAdditionalProperties": "throw-on-extras",
  "controllerPathGlobs": ["controllers/**/*Controller.ts"],
  "spec": {
    "outputDirectory": "public",
    "specVersion": 3,
    "name": "Attendance Backend API",
    "description": "API documentation for attendance management system",
    "version": "1.0.0",
    "contact": {
      "name": "API Support"
    },
    "securityDefinitions": {
      "jwt": {
        "type": "apiKey",
        "name": "Authorization",
        "in": "header",
        "description": "JWT token (Bearer <token>)"
      }
    }
  },
  "routes": {
    "routesDir": "generated",
    "middleware": "express",
    "authenticationModule": "./middlewares/auth.ts"
  }
}
